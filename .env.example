# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/earningproject

# Auth (use long random strings in production)
JWT_SECRET=change-me-to-a-long-random-string
WALLET_ENCRYPTION_KEY=change-me-wallet-encryption-key-min-16-chars

# Email OTP (optional — if omitted, OTP prints in server console)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourdomain.com
# Display name in inbox (not the Gmail/login address)
PLATFORM_NAME=Earning

# Deposit / blockchain monitoring (optional)
TRONGRID_API_KEY=
BSC_RPC_URL=https://bsc-dataseed.binance.org/
BLOCKCHAIN_MONITOR_ENABLED=true
CRON_SECRET=change-me-cron-secret
STALE_PENDING_HOURS=72
STUCK_WITHDRAWAL_HOURS=48
MONITOR_USER_BATCH=50

# Daily profit (24h rolling cycle per active plan — no blockchain API needed)
PROFIT_CYCLE_HOURS=24
# Optional: call POST /api/cron/accrue-profits with Authorization: Bearer $CRON_SECRET

# Admin portal (change password in production)
ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD=12345678
ADMIN_USERNAME=admin

# Withdrawals (manual admin payout by default)
WITHDRAW_AUTO_APPROVE=false
WITHDRAW_AUTO_SEND=false
WITHDRAW_DRY_RUN=true
ADMIN_SECRET=
MIN_WITHDRAW_USDT=1
WITHDRAW_FEE_USDT=1
MAX_DAILY_WITHDRAW_USDT=5000
